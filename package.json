{
  "name": "creator-commerce",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev:engine": "pnpm --filter design-engine dev",
    "dev:portal": "pnpm --filter portal dev",
    "dev:admin": "pnpm --filter admin dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:migrate": "node scripts/migrate.js",
    "db:status": "node scripts/migrate.js --status",
    "db:reset": "node scripts/migrate.js --reset"
  },
  "devDependencies": {
    "pg": "^8.20.0"
  }
}
